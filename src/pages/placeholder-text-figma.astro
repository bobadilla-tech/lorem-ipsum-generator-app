---
import AdContainer from "../components/layout/AdContainer.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How do I add placeholder text to a Figma design?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Generate plain text from a Lorem Ipsum generator, copy it, then paste it directly into any Figma text layer — Figma accepts plain text pasted from the clipboard with no special import step.",
      },
    },
    {
      "@type": "Question",
      name: "Are there Figma plugins for Lorem Ipsum?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes, several exist in the Figma Community plugin directory. A plain-text generator works just as well for most cases and doesn't require installing anything into your Figma account.",
      },
    },
    {
      "@type": "Question",
      name: "Should I use HTML or plain text format for Figma?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Plain text. Figma text layers don't render HTML tags, so pasting HTML-formatted output will show the literal tags instead of formatted text.",
      },
    },
  ],
};
---

<BaseLayout
  title="Placeholder Text for Figma - Copy-Paste Lorem Ipsum Generator"
  description="Generate Lorem Ipsum placeholder text and paste it straight into Figma text layers. Plain text output, sized to fit real components, no plugin required."
  keywords={['placeholder text for figma', 'lorem ipsum generator for figma', 'figma lorem ipsum', 'dummy text for figma', 'lorem ipsum generator for website']}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <div class="container">
    <article class="content-article">
      <header class="article-header">
        <h1 class="article-title">Placeholder Text for <span class="text-gradient">Figma</span></h1>
        <p class="article-subtitle">Copy plain text, paste it straight into any text layer</p>
      </header>

      <div class="article-content">
        <section class="content-section">
          <p>
            Figma text layers accept plain text pasted from the clipboard — no plugin, no import step. Generate the
            length you need below, hit copy, and paste it directly into your design.
          </p>
        </section>

        <section class="content-section">
          <h2>Workflow</h2>
          <div class="use-case">
            <h3>1. Set the Format to Plain Text</h3>
            <p>Figma text layers don't render HTML or Markdown — pasting either will show the raw tags instead of formatted text. Keep the format dropdown on "Plain Text".</p>
          </div>
          <div class="use-case">
            <h3>2. Match Count to the Layer</h3>
            <p>Use words for labels and buttons, sentences for short descriptions, paragraphs for body copy and long-form sections.</p>
          </div>
          <div class="use-case">
            <h3>3. Copy and Paste</h3>
            <p>Use <kbd>Ctrl</kbd>+<kbd>K</kbd> to copy from the generator, then paste directly into the selected Figma text layer.</p>
          </div>
        </section>

        <AdContainer
          adSlot="9900112233"
          adFormat="rectangle"
          className="ad-content"
        />

        <section class="content-section">
          <h2>Figma Plugins vs. a Plain Generator</h2>
          <p>
            Figma's Community directory has several Lorem Ipsum plugins that generate text inside the canvas
            directly. They're convenient if you're already deep in a file and don't want to alt-tab out. A
            standalone generator works just as well for most workflows and needs nothing installed into your Figma
            account — useful if you're designing on a machine where you can't add plugins, or just prefer copy-paste.
          </p>
        </section>

        <section class="content-section cta-section">
          <h2>Generate Plain Text for Figma</h2>
          <p>
            Format is already set to plain text below — pick a count, generate, and paste.
          </p>
          <a href="/" class="button button-primary">Generate Lorem Ipsum →</a>
        </section>
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .content-article {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .article-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--border);
  }

  .article-title {
    font-size: 3rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .article-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    font-weight: 400;
  }

  .article-content {
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .content-section {
    margin-bottom: 3rem;
  }

  .content-section h2 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    margin-top: 2rem;
  }

  .ad-content {
    margin: 3rem auto;
    max-width: 600px;
  }

  .use-case {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--accent);
  }

  .use-case h3 {
    margin-bottom: 1rem;
    color: var(--accent);
  }

  .use-case kbd {
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.125rem 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  .cta-section {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--bg-glass);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    margin-top: 4rem;
  }

  .cta-section h2 {
    margin-top: 0;
  }

  .cta-section p {
    margin-bottom: 2rem;
  }

  @media (max-width: 768px) {
    .article-title {
      font-size: 2rem;
    }

    .article-subtitle {
      font-size: 1rem;
    }
  }
</style>
