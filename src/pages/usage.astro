---
import AdContainer from "../components/layout/AdContainer.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Why use Lorem Ipsum instead of real content?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Lorem Ipsum lets designers and developers evaluate a layout without being distracted by readable content, so stakeholders focus on visual design rather than copy.",
      },
    },
    {
      "@type": "Question",
      name: "Should I replace Lorem Ipsum before launching my site?",
      acceptedAnswer: {
        "@type": "Answer",
        text: 'Yes. Always replace Lorem Ipsum with real content before going live, and search your codebase for "lorem" to catch any missed instances.',
      },
    },
    {
      "@type": "Question",
      name: "Does Lorem Ipsum hurt SEO if it's left on a live page?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Never launch with Lorem Ipsum in meta descriptions, titles, or H1 tags, since it hurts search rankings by replacing meaningful, indexable content.",
      },
    },
    {
      "@type": "Question",
      name: "Can I generate Lorem Ipsum in HTML or Markdown format?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Our generator outputs Plain Text, HTML, or Markdown so it drops directly into your workflow, whether that's a CMS, a static site, or code.",
      },
    },
  ],
};
---

<BaseLayout
  title="How to Use Lorem Ipsum - Usage Guide for Designers"
  description="Learn how designers and developers use Lorem Ipsum placeholder text effectively. Best practices, common use cases, and tips for maximum efficiency."
  keywords={['lorem ipsum usage', 'placeholder text guide', 'dummy text best practices', 'design mockups']}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <div class="container">
    <article class="content-article">
      <header class="article-header">
        <h1 class="article-title">How to Use <span class="text-gradient">Lorem Ipsum</span></h1>
        <p class="article-subtitle">Best practices for designers and developers</p>
      </header>

      <div class="article-content">
        <section class="content-section">
          <h2>Why Use Lorem Ipsum?</h2>
          <p>
            Lorem Ipsum allows designers and developers to focus on visual design without being distracted by readable
            content. It helps stakeholders evaluate layouts without getting caught up in copywriting.
          </p>
          <div class="benefit-grid">
            <div class="benefit-card">
              <div class="benefit-icon">🎨</div>
              <h3>Focus on Design</h3>
              <p>Evaluate layouts without distraction from readable content</p>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">📏</div>
              <h3>Realistic Sizing</h3>
              <p>See how real content will look and flow in your design</p>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">⚡</div>
              <h3>Save Time</h3>
              <p>No need to wait for final copy during design phase</p>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">👥</div>
              <h3>Client Review</h3>
              <p>Present designs without placeholder text confusion</p>
            </div>
          </div>
        </section>

        <section class="content-section">
          <h2>Common Use Cases</h2>

          <div class="use-case">
            <h3>1. Website Mockups</h3>
            <p>
              Use Lorem Ipsum to fill content areas in website designs before final copy is ready. This helps clients
              visualize the layout and flow.
            </p>
            <div class="code-example">
              <strong>Example:</strong> Homepage hero section, blog posts, product descriptions
            </div>
          </div>

          <div class="use-case">
            <h3>2. Print Design</h3>
            <p>
              Magazines, brochures, and posters often need placeholder text during the design phase to show text
              hierarchy and spacing.
            </p>
            <div class="code-example">
              <strong>Example:</strong> Magazine layouts, brochure templates, poster designs
            </div>
          </div>

          <div class="use-case">
            <h3>3. App Prototypes</h3>
            <p>
              Mobile and web app prototypes benefit from realistic placeholder text to demonstrate user flows and
              interface designs.
            </p>
            <div class="code-example">
              <strong>Example:</strong> User profiles, news feeds, product listings
            </div>
          </div>

          <div class="use-case">
            <h3>4. Typography Testing</h3>
            <p>
              Test font sizes, line heights, and readability with Lorem Ipsum before committing to a typeface.
            </p>
            <div class="code-example">
              <strong>Example:</strong> Font selection, hierarchy testing, spacing adjustments
            </div>
          </div>
        </section>

        <section class="content-section">
          <h2>Best Practices</h2>

          <ul class="best-practices-list">
            <li>
              <strong>Use Appropriate Length</strong>
              <p>Match the placeholder text length to realistic content. Don't use 5 paragraphs where you'll only have 2.</p>
            </li>
            <li>
              <strong>Replace Before Launch</strong>
              <p>Always replace Lorem Ipsum with real content before going live. Search for "lorem" to catch any missed instances.</p>
            </li>
            <li>
              <strong>Consider SEO</strong>
              <p>Never launch with Lorem Ipsum in meta descriptions, titles, or H1 tags. This hurts search rankings.</p>
            </li>
            <li>
              <strong>Use Realistic Headings</strong>
              <p>For headings, use actual headline lengths (5-10 words) rather than full Lorem Ipsum sentences.</p>
            </li>
            <li>
              <strong>Test Edge Cases</strong>
              <p>Try very short and very long placeholder text to see how your design handles different content lengths.</p>
            </li>
            <li>
              <strong>Label Clearly</strong>
              <p>When sharing designs, note that Lorem Ipsum is placeholder text to avoid confusion with stakeholders.</p>
            </li>
          </ul>
        </section>

        <section class="content-section">
          <h2>Tips for Different Tools</h2>

          <div class="tool-tips">
            <div class="tool-card">
              <h3>Figma / Sketch</h3>
              <ul>
                <li>Use text generation plugins for quick Lorem Ipsum</li>
                <li>Create text styles with Lorem Ipsum for reusability</li>
                <li>Test responsive breakpoints with varying text lengths</li>
              </ul>
              <a href="/placeholder-text-figma" class="inline-link">Full Figma copy-paste guide →</a>
            </div>

            <div class="tool-card">
              <h3>Adobe XD / Photoshop</h3>
              <ul>
                <li>Use repeat grids with Lorem Ipsum for consistent layouts</li>
                <li>Save frequently used Lorem Ipsum as text snippets</li>
                <li>Test accessibility with different font sizes</li>
              </ul>
            </div>

            <div class="tool-card">
              <h3>WordPress / CMS</h3>
              <ul>
                <li>Use Lorem Ipsum for demo content during theme development</li>
                <li>Test custom post types and taxonomies</li>
                <li>Verify responsive behavior across devices</li>
              </ul>
            </div>

            <div class="tool-card">
              <h3>HTML/CSS Development</h3>
              <ul>
                <li>Use our generator to create Lorem Ipsum in HTML format</li>
                <li>Test text overflow and truncation</li>
                <li>Verify line-height and letter-spacing</li>
              </ul>
            </div>
          </div>
        </section>

        <AdContainer
          adSlot="6677889900"
          adFormat="rectangle"
          className="ad-content"
        />

        <section class="content-section">
          <h2>What NOT to Do</h2>

          <div class="warning-box">
            <h3>⚠️ Common Mistakes to Avoid</h3>
            <ul>
              <li><strong>Don't launch with Lorem Ipsum</strong> - Always replace with real content</li>
              <li><strong>Don't use for final presentations</strong> - Use realistic content for client sign-off</li>
              <li><strong>Don't ignore accessibility</strong> - Test screen readers with real content, not Lorem Ipsum</li>
              <li><strong>Don't copy-paste repeatedly</strong> - Use a generator for variety and natural text flow</li>
              <li><strong>Don't use in production databases</strong> - Clean up test data before launch</li>
            </ul>
          </div>
        </section>

        <section class="content-section">
          <h2>Need This in Your Own App?</h2>
          <p>
            If you're generating placeholder text programmatically instead of by hand, skip the copy-paste and use it
            directly in code.
          </p>

          <div class="dev-tools-grid">
            <div class="dev-tool-card">
              <img src="/images/gopher.png" alt="Lorelai" class="dev-tool-logo" width="40" height="40" />
              <h4>Lorelai Go Library</h4>
              <p>Open source Lorem Ipsum generator for Go applications</p>
              <a href="https://github.com/bobadilla-tech/lorelai" target="_blank" rel="noopener noreferrer" class="link-button">
                View on GitHub →
              </a>
            </div>

            <div class="dev-tool-card">
              <img src="/images/requiems-api-logo.png" alt="Requiems API" class="dev-tool-logo" width="40" height="40" />
              <h4>Requiems API</h4>
              <p>Lorem Ipsum generation as one endpoint in an all-in-one SaaS backend</p>
              <a href="https://requiems.xyz/" target="_blank" rel="noopener noreferrer" class="link-button">
                View API Docs →
              </a>
            </div>
          </div>
        </section>

        <section class="content-section cta-section">
          <h2>Start Generating Lorem Ipsum</h2>
          <p>
            Use our modern generator to create placeholder text for your next project. Fast, free, and perfect for any
            design workflow.
          </p>
          <a href="/" class="button button-primary">Generate Now →</a>
        </section>
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .content-article {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .article-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--border);
  }

  .article-title {
    font-size: 3rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .article-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    font-weight: 400;
  }

  .article-content {
    font-size: 1.125rem;
    line-height: 1.8;
  }

  .content-section {
    margin-bottom: 3rem;
  }

  .content-section h2 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    margin-top: 2rem;
  }

  .ad-content {
    margin: 3rem auto;
    max-width: 600px;
  }

  .benefit-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .benefit-card {
    background: var(--bg-secondary);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    text-align: center;
    border: 1px solid var(--border);
  }

  .benefit-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .benefit-card h3 {
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }

  .benefit-card p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .use-case {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--accent);
  }

  .use-case h3 {
    margin-bottom: 1rem;
    color: var(--accent);
  }

  .use-case p {
    margin-bottom: 1rem;
  }

  .code-example {
    background: var(--bg-primary);
    padding: 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    font-size: 0.9375rem;
    color: var(--text-secondary);
  }

  .best-practices-list {
    list-style: none;
    padding: 0;
  }

  .best-practices-list li {
    margin-bottom: 1.5rem;
    padding: 1.5rem;
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    border-left: 3px solid var(--accent);
  }

  .best-practices-list strong {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
    font-size: 1.125rem;
  }

  .best-practices-list p {
    margin: 0;
    color: var(--text-secondary);
  }

  .tool-tips {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .tool-card {
    background: var(--bg-secondary);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }

  .tool-card h3 {
    margin-bottom: 1rem;
    color: var(--accent);
  }

  .tool-card ul {
    margin: 0;
    padding-left: 1.5rem;
  }

  .tool-card li {
    margin-bottom: 0.5rem;
    color: var(--text-secondary);
  }

  .inline-link {
    display: inline-block;
    margin-top: 0.5rem;
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9375rem;
  }

  .inline-link:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }

  .warning-box {
    background: rgba(239, 68, 68, 0.1);
    border: 2px solid rgba(239, 68, 68, 0.3);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin: 2rem 0;
  }

  .warning-box h3 {
    color: #ef4444;
    margin-bottom: 1rem;
  }

  .warning-box ul {
    margin: 0;
    padding-left: 1.5rem;
  }

  .warning-box li {
    margin-bottom: 0.75rem;
  }

  .dev-tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin: 2rem 0;
  }

  .dev-tool-card {
    background: var(--bg-secondary);
    padding: 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }

  .dev-tool-logo {
    border-radius: var(--radius-md);
    object-fit: cover;
    margin-bottom: 0.75rem;
  }

  .dev-tool-card h4 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .dev-tool-card p {
    margin-bottom: 1.5rem;
    color: var(--text-secondary);
  }

  .link-button {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--accent);
    color: #0b0505;
    text-decoration: none;
    border-radius: var(--radius-md);
    font-weight: 500;
    transition: background var(--transition-fast);
  }

  .link-button:hover {
    background: var(--accent-hover);
  }

  .cta-section {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--bg-glass);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    margin-top: 4rem;
  }

  .cta-section h2 {
    margin-top: 0;
  }

  .cta-section p {
    margin-bottom: 2rem;
  }

  @media (max-width: 768px) {
    .article-title {
      font-size: 2rem;
    }

    .article-subtitle {
      font-size: 1rem;
    }

    .benefit-grid {
      grid-template-columns: 1fr;
    }

    .tool-tips {
      grid-template-columns: 1fr;
    }
  }
</style>
