---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Terms of Service - Lorem Ipsum Generator"
  description="Terms of service for using Lorem Ipsum Generator."
>
  <div class="container">
    <article class="content-article">
      <header class="article-header">
        <h1 class="article-title">Terms of Service</h1>
        <p class="article-subtitle">Last updated: January 30, 2026</p>
      </header>

      <div class="article-content">
        <section class="content-section">
          <h2>Agreement to Terms</h2>
          <p>
            By accessing and using Lorem Ipsum Generator, you accept and agree to be bound by these Terms of Service.
            If you do not agree to these terms, please do not use our service.
          </p>
        </section>

        <section class="content-section">
          <h2>Use of Service</h2>
          <p>Our service is provided free of charge for personal and commercial use. You may:</p>
          <ul>
            <li>Generate Lorem Ipsum text for any purpose</li>
            <li>Use generated text in commercial projects</li>
            <li>Copy and distribute generated text</li>
          </ul>
        </section>

        <section class="content-section">
          <h2>Restrictions</h2>
          <p>You agree not to:</p>
          <ul>
            <li>Attempt to reverse engineer or copy our generator algorithm</li>
            <li>Use automated tools to scrape or abuse our service</li>
            <li>Resell or redistribute our service as your own</li>
            <li>Use the service for illegal purposes</li>
          </ul>
        </section>

        <section class="content-section">
          <h2>Intellectual Property</h2>
          <p>
            The generated Lorem Ipsum text is in the public domain and free to use. However, our website design,
            branding, and code are protected by copyright and owned by Bobadilla Tech.
          </p>
        </section>

        <section class="content-section">
          <h2>Disclaimer of Warranties</h2>
          <p>
            This service is provided "as is" without warranties of any kind. We do not guarantee that the service will
            be uninterrupted or error-free.
          </p>
        </section>

        <section class="content-section">
          <h2>Limitation of Liability</h2>
          <p>
            In no event shall Lorem Ipsum Generator or Bobadilla Tech be liable for any indirect, incidental, special,
            or consequential damages arising from your use of the service.
          </p>
        </section>

        <section class="content-section">
          <h2>Changes to Terms</h2>
          <p>
            We reserve the right to modify these terms at any time. Continued use of the service after changes
            constitutes acceptance of the new terms.
          </p>
        </section>

        <section class="content-section">
          <h2>Contact</h2>
          <p>
            For questions about these Terms, please <a href="/contact">contact us</a>.
          </p>
        </section>
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .content-article {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .article-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--border);
  }

  .article-title {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .article-subtitle {
    font-size: 1rem;
    color: var(--text-secondary);
  }

  .article-content {
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .content-section {
    margin-bottom: 2.5rem;
  }

  .content-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    margin-top: 2rem;
  }

  .content-section ul {
    margin: 1rem 0;
    padding-left: 2rem;
  }

  .content-section li {
    margin-bottom: 0.5rem;
  }

  @media (max-width: 768px) {
    .article-title {
      font-size: 2rem;
    }
  }
</style>
