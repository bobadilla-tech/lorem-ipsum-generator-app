---
import AdContainer from "../components/layout/AdContainer.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What are the most popular alternatives to Lorem Ipsum?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Popular themed alternatives include Bacon Ipsum, Cat Ipsum, Hipster Ipsum, Corporate Ipsum, Gamer Ipsum, and Movie Ipsum, each swapping in themed vocabulary while keeping the same placeholder-text purpose.",
      },
    },
    {
      "@type": "Question",
      name: "Should I use a themed Lorem Ipsum alternative for client work?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "For formal business proposals, conservative industries, or international clients, stick with traditional Lorem Ipsum. Themed alternatives work best for fun personal projects or internal tools where you know your audience.",
      },
    },
    {
      "@type": "Question",
      name: "Can I generate Lorem Ipsum programmatically instead of using alternative generators?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. The Lorelai Go library and Requiems API both let you generate standard Lorem Ipsum text directly in code, without copy-pasting from a website.",
      },
    },
  ],
};
---

<BaseLayout
  title="Lorem Ipsum Alternatives - Other Placeholder Text Generators"
  description="Explore alternative placeholder text generators and dummy content tools. From Bacon Ipsum to Cat Ipsum, find the perfect placeholder for your project."
  keywords={['lorem ipsum alternatives', 'placeholder text generators', 'dummy text tools', 'bacon ipsum', 'cat ipsum']}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <div class="container">
    <article class="content-article">
      <header class="article-header">
        <h1 class="article-title">Lorem Ipsum <span class="text-gradient">Alternatives</span></h1>
        <p class="article-subtitle">Fun and creative placeholder text generators</p>
      </header>

      <div class="article-content">
        <section class="content-section">
          <p>
            While Lorem Ipsum is the industry standard, sometimes you want something different. Here are some creative
            alternatives for placeholder text in your designs.
          </p>
        </section>

        <section class="content-section">
          <h2>Popular Alternatives</h2>
          <p>
            These are real, independently-run generators — not made up for this list. Each one swaps the Latin for a
            theme, follow the link to try the actual tool.
          </p>

          <div class="alternative-card">
            <h3>🥓 Bacon Ipsum</h3>
            <p class="alt-description">
              Meat-themed Lorem Ipsum generator. Perfect for food-related projects and adding humor to your mockups.
            </p>
            <div class="example-text">
              "Bacon ipsum dolor amet pork chop tenderloin chicken, hamburger ribeye bresaola cupim..."
            </div>
            <a href="https://www.baconipsum.com/" target="_blank" rel="noopener noreferrer" class="link-button">
              Visit Bacon Ipsum →
            </a>
          </div>

          <div class="alternative-card">
            <h3>😺 Cat Ipsum</h3>
            <p class="alt-description">
              Cat-themed placeholder text with feline behaviors and phrases. Great for pet-related websites.
            </p>
            <div class="example-text">
              "Meow all night having their mate disturbing sleeping humans purr like a car engine..."
            </div>
            <a href="http://www.catipsum.com/" target="_blank" rel="noopener noreferrer" class="link-button">
              Visit Cat Ipsum →
            </a>
          </div>

          <div class="alternative-card">
            <h3>🍺 Hipster Ipsum</h3>
            <p class="alt-description">
              Trendy, ironic placeholder text featuring craft beer, artisanal goods, and hipster culture references.
            </p>
            <div class="example-text">
              "Flannel viral jean shorts, sriracha chia cronut asymmetrical small batch..."
            </div>
            <a href="https://hipsum.co/" target="_blank" rel="noopener noreferrer" class="link-button">
              Visit Hipster Ipsum →
            </a>
          </div>

          <div class="alternative-card">
            <h3>👔 Corporate Ipsum</h3>
            <p class="alt-description">
              Business jargon and corporate buzzwords. Ideal for business presentations and enterprise mockups.
            </p>
            <div class="example-text">
              "Synergize cross-platform initiatives to leverage core competencies and maximize ROI..."
            </div>
            <a href="https://corporatelorem.kovah.de/" target="_blank" rel="noopener noreferrer" class="link-button">
              Visit Corporate Lorem →
            </a>
          </div>

          <div class="alternative-card">
            <h3>🎮 Gamer Ipsum</h3>
            <p class="alt-description">
              Gaming-themed placeholder text with references to popular games and gaming culture.
            </p>
            <div class="example-text">
              "Level up your gameplay with strategic power-ups and achieve legendary status..."
            </div>
            <a href="https://placeholdertext.org/themed/gaming-ipsum/" target="_blank" rel="noopener noreferrer" class="link-button">
              Visit Gaming Ipsum →
            </a>
          </div>

          <div class="alternative-card">
            <h3>🎬 Movie Ipsum</h3>
            <p class="alt-description">
              Famous movie quotes and cinema references. Perfect for entertainment and media projects.
            </p>
            <div class="example-text">
              "You talking to me? May the force be with you as you complete the mission..."
            </div>
            <a href="https://moviesipsum.com/" target="_blank" rel="noopener noreferrer" class="link-button">
              Visit Movies Ipsum →
            </a>
          </div>
        </section>

        <AdContainer
          adSlot="4455667788"
          adFormat="rectangle"
          className="ad-content"
        />

        <section class="content-section">
          <h2>When to Use Alternatives</h2>

          <div class="use-case-grid">
            <div class="use-case-card">
              <h4>For Fun Projects</h4>
              <p>Add personality to personal projects or internal tools</p>
            </div>

            <div class="use-case-card">
              <h4>Theme-Specific Designs</h4>
              <p>Match placeholder text to your project's theme or industry</p>
            </div>

            <div class="use-case-card">
              <h4>Client Presentations</h4>
              <p>Make mockups more engaging and memorable</p>
            </div>

            <div class="use-case-card">
              <h4>Testing Edge Cases</h4>
              <p>Test how your design handles unconventional content</p>
            </div>
          </div>
        </section>

        <section class="content-section">
          <div class="warning-box">
            <h3>⚠️ Professional Considerations</h3>
            <p>
              While alternative placeholder text can be fun, stick with traditional Lorem Ipsum for:
            </p>
            <ul>
              <li>Client presentations (unless you know your audience well)</li>
              <li>Formal business proposals</li>
              <li>Projects in conservative industries</li>
              <li>International clients who may not understand cultural references</li>
            </ul>
          </div>
        </section>

        <section class="content-section">
          <h2>Our Developer Tools</h2>
          <p>Need programmatic access to Lorem Ipsum generation?</p>

          <div class="dev-tools-grid">
            <div class="dev-tool-card">
              <img src="/images/gopher.png" alt="Lorelai" class="dev-tool-logo" width="40" height="40" />
              <h4>Lorelai Go Library</h4>
              <p>Open source Lorem Ipsum generator for Go applications</p>
              <a href="https://github.com/bobadilla-tech/lorelai" target="_blank" rel="noopener noreferrer" class="link-button">
                View on GitHub →
              </a>
            </div>

            <div class="dev-tool-card">
              <img src="/images/requiems-api-logo.png" alt="Requiems API" class="dev-tool-logo" width="40" height="40" />
              <h4>Requiems API</h4>
              <p>Production-ready REST API for high-volume generation</p>
              <a href="https://requiems.xyz/" target="_blank" rel="noopener noreferrer" class="link-button">
                View API Docs →
              </a>
            </div>
          </div>
        </section>

        <section class="content-section cta-section">
          <h2>Stick with the Classic</h2>
          <p>
            For professional projects, nothing beats traditional Lorem Ipsum. Use our generator for fast, reliable
            placeholder text.
          </p>
          <a href="/" class="button button-primary">Generate Lorem Ipsum →</a>
        </section>
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .content-article {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .article-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--border);
  }

  .article-title {
    font-size: 3rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .article-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    font-weight: 400;
  }

  .article-content {
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .content-section {
    margin-bottom: 3rem;
  }

  .content-section h2 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    margin-top: 2rem;
  }

  .ad-content {
    margin: 3rem auto;
    max-width: 600px;
  }

  .alternative-card {
    background: var(--bg-secondary);
    padding: 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    margin-bottom: 2rem;
    border-left: 4px solid var(--accent);
  }

  .alternative-card h3 {
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .alt-description {
    margin-bottom: 1rem;
    color: var(--text-secondary);
  }

  .example-text {
    background: var(--bg-primary);
    padding: 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    font-style: italic;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .use-case-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .use-case-card {
    background: var(--bg-secondary);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    text-align: center;
  }

  .use-case-card h4 {
    margin-bottom: 0.75rem;
    color: var(--accent);
  }

  .use-case-card p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .warning-box {
    background: rgba(251, 191, 36, 0.1);
    border: 2px solid rgba(251, 191, 36, 0.3);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin: 2rem 0;
  }

  .warning-box h3 {
    color: #f59e0b;
    margin-bottom: 1rem;
  }

  .warning-box ul {
    margin: 0.5rem 0 0 1.5rem;
  }

  .warning-box li {
    margin-bottom: 0.5rem;
  }

  .dev-tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin: 2rem 0;
  }

  .dev-tool-card {
    background: var(--bg-secondary);
    padding: 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }

  .dev-tool-logo {
    border-radius: var(--radius-md);
    object-fit: cover;
    margin-bottom: 0.75rem;
  }

  .dev-tool-card h4 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .dev-tool-card p {
    margin-bottom: 1.5rem;
    color: var(--text-secondary);
  }

  .link-button {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--accent);
    color: #0b0505;
    text-decoration: none;
    border-radius: var(--radius-md);
    font-weight: 500;
    transition: background var(--transition-fast);
  }

  .link-button:hover {
    background: var(--accent-hover);
  }

  .cta-section {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--bg-glass);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    margin-top: 4rem;
  }

  .cta-section h2 {
    margin-top: 0;
  }

  .cta-section p {
    margin-bottom: 2rem;
  }

  @media (max-width: 768px) {
    .article-title {
      font-size: 2rem;
    }

    .use-case-grid {
      grid-template-columns: 1fr;
    }

    .dev-tools-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
