---
import BaseLayout from '../layouts/BaseLayout.astro';
import GeneratorControls from '../components/generator/GeneratorControls.astro';
import OutputDisplay from '../components/generator/OutputDisplay.astro';
import AdContainer from '../components/layout/AdContainer.astro';
---

<BaseLayout
  title="Lorem Ipsum Generator - Free Placeholder Text, Email, URL & Domain Generator"
  description="Generate Lorem Ipsum text, random email addresses, URLs, and domain names instantly. Fast, modern, and completely free. Perfect for designers, developers, and testing."
  keywords={['lorem ipsum generator', 'placeholder text', 'dummy text generator', 'email generator', 'random email generator', 'url generator', 'domain name generator', 'fake email', 'test data generator', 'lorem ipsum']}
>
  <div class="container">
    <!-- Hero Section with Generator -->
    <section class="hero-section">
      <GeneratorControls />
      <OutputDisplay />

      <!-- Feature Highlight -->
      <div class="feature-highlight">
        <p class="highlight-text">
          <strong>NEW:</strong> Now generate random emails, URLs, and domain names for testing!
        </p>
      </div>
    </section>

    <!-- Ad Slot 1: Leaderboard -->
    <AdContainer
      adSlot="1234567890"
      adFormat="horizontal"
      className="ad-leaderboard"
    />

    <!-- Educational Content Section 1: What is Lorem Ipsum? -->
    <section class="content-section">
      <h2 class="section-title">What is Lorem Ipsum?</h2>
      <div class="content-grid">
        <div class="content-main">
          <p>
            Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the
            industry's standard dummy text ever since the 1500s, when an unknown printer took a galley of type and
            scrambled it to make a type specimen book. It has survived not only five centuries, but also the leap into
            electronic typesetting, remaining essentially unchanged.
          </p>
          <p>
            It was popularised in the 1960s with the release of Letraset sheets containing Lorem Ipsum passages, and
            more recently with desktop publishing software like Aldus PageMaker including versions of Lorem Ipsum.
          </p>
          <p>
            <strong>Why do we use it?</strong> It is a long established fact that a reader will be distracted by the
            readable content of a page when looking at its layout. The point of using Lorem Ipsum is that it has a
            more-or-less normal distribution of letters, as opposed to using 'Content here, content here', making it
            look like readable English.
          </p>
          <p>
            Many desktop publishing packages and web page editors now use Lorem Ipsum as their default model text, and
            a search for 'lorem ipsum' will uncover many web sites still in their infancy. Various versions have evolved
            over the years, sometimes by accident, sometimes on purpose (injected humour and the like).
          </p>
        </div>

        <!-- Ad Slot 2: Sidebar Rectangle (Desktop) -->
        <aside class="sidebar-ad">
          <AdContainer
            adSlot="0987654321"
            adFormat="rectangle"
            className="ad-sidebar"
          />
        </aside>
      </div>
    </section>

    <!-- Educational Content Section 2: Where does it come from? -->
    <section class="content-section">
      <h2 class="section-title">Where Does Lorem Ipsum Come From?</h2>
      <div class="content-card glass-card">
        <p>
          Contrary to popular belief, Lorem Ipsum is not simply random text. It has roots in a piece of classical Latin
          literature from 45 BC, making it over 2000 years old.
        </p>
        <p>
          <strong>Richard McClintock</strong>, a Latin professor at Hampden-Sydney College in Virginia, looked up one
          of the more obscure Latin words, <em>consectetur</em>, from a Lorem Ipsum passage, and going through the
          cites of the word in classical literature, discovered the undoubtable source.
        </p>
        <blockquote class="quote-box">
          Lorem Ipsum comes from sections 1.10.32 and 1.10.33 of "de Finibus Bonorum et Malorum" (The Extremes of Good
          and Evil) by Cicero, written in 45 BC. This book is a treatise on the theory of ethics, very popular during
          the Renaissance.
        </blockquote>
        <p>
          The first line of Lorem Ipsum, "Lorem ipsum dolor sit amet..", comes from a line in section 1.10.32. The
          standard chunk of Lorem Ipsum used since the 1500s is reproduced below for those interested.
        </p>
        <div class="classic-text">
          <h3>The Standard Lorem Ipsum Passage</h3>
          <p class="latin-text">
            "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et
            dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex
            ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu
            fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt
            mollit anim id est laborum."
          </p>
        </div>
        <p>
          <a href="/history" class="inline-link">Learn more about the fascinating history of Lorem Ipsum →</a>
        </p>
      </div>
    </section>

    <!-- Test Data Generation Section -->
    <section class="test-data-section">
      <div class="test-data-container glass-card">
        <h2 class="section-title text-center">Perfect for Testing & Development</h2>
        <p class="section-intro">
          Beyond Lorem Ipsum text, generate realistic test data for your applications:
        </p>

        <div class="test-data-grid">
          <div class="test-data-card">
            <div class="test-icon">📧</div>
            <h3>Email Addresses</h3>
            <p>Generate fake email addresses for testing user registration, forms, and email validation.</p>
            <div class="example-box">
              <code>lorem.ipsum@gmail.com<br/>dolor.sit@example.com</code>
            </div>
            <ul class="use-cases">
              <li>Testing form validation</li>
              <li>Populating databases</li>
              <li>User interface mockups</li>
            </ul>
          </div>

          <div class="test-data-card">
            <div class="test-icon">🌐</div>
            <h3>URLs</h3>
            <p>Create realistic URLs with domains and paths for testing links and navigation.</p>
            <div class="example-box">
              <code>https://loremipsum.com/blog<br/>https://dolorsit.dev/products</code>
            </div>
            <ul class="use-cases">
              <li>Testing link components</li>
              <li>Navigation prototypes</li>
              <li>SEO tool testing</li>
            </ul>
          </div>

          <div class="test-data-card">
            <div class="test-icon">🔗</div>
            <h3>Domain Names</h3>
            <p>Generate random domain names with various TLDs for testing and prototyping.</p>
            <div class="example-box">
              <code>loremipsum.io<br/>consectetur.tech</code>
            </div>
            <ul class="use-cases">
              <li>DNS tool testing</li>
              <li>Domain search features</li>
              <li>Hosting prototypes</li>
            </ul>
          </div>
        </div>

        <div class="cta-box">
          <p><strong>Try it now:</strong> Select "Email Addresses", "URLs", or "Domain Names" from the Unit dropdown above!</p>
        </div>
      </div>
    </section>

    <!-- Ad Slot 3: In-Content Rectangle -->
    <AdContainer
      adSlot="1122334455"
      adFormat="rectangle"
      className="ad-content"
    />

    <!-- Features Section -->
    <section class="features-section">
      <h2 class="section-title text-center">Why Use Our Generator?</h2>
      <div class="features-grid">
        <div class="feature-card glass-card">
          <div class="feature-icon">📝</div>
          <h3>Lorem Ipsum Text</h3>
          <p>Generate classic placeholder text by paragraphs, sentences, or words. Perfect for mockups.</p>
        </div>

        <div class="feature-card glass-card highlight-card">
          <div class="feature-icon">📧</div>
          <h3>Random Emails</h3>
          <p>Generate fake email addresses for testing forms, databases, and user interfaces.</p>
        </div>

        <div class="feature-card glass-card highlight-card">
          <div class="feature-icon">🌐</div>
          <h3>Random URLs</h3>
          <p>Create realistic-looking URLs with domains and paths for testing link features.</p>
        </div>

        <div class="feature-card glass-card highlight-card">
          <div class="feature-icon">🔗</div>
          <h3>Domain Names</h3>
          <p>Generate random domain names with various TLDs for prototyping and testing.</p>
        </div>

        <div class="feature-card glass-card">
          <div class="feature-icon">🎨</div>
          <h3>Multiple Formats</h3>
          <p>Export as plain text, HTML, or Markdown. Perfect for any workflow or design tool.</p>
        </div>

        <div class="feature-card glass-card">
          <div class="feature-icon">⚡</div>
          <h3>Lightning Fast</h3>
          <p>Generate content instantly with our optimized algorithm. No loading, no delays.</p>
        </div>

        <div class="feature-card glass-card">
          <div class="feature-icon">📱</div>
          <h3>Mobile Friendly</h3>
          <p>Works perfectly on all devices. Generate placeholder data anywhere, anytime.</p>
        </div>

        <div class="feature-card glass-card">
          <div class="feature-icon">🔒</div>
          <h3>100% Free</h3>
          <p>No sign-up, no limits, no hidden fees. Generate as much as you need.</p>
        </div>

        <div class="feature-card glass-card">
          <div class="feature-icon">⌨️</div>
          <h3>Keyboard Shortcuts</h3>
          <p>Work faster with Ctrl+G to generate and Ctrl+K to copy. Designed for efficiency.</p>
        </div>

        <div class="feature-card glass-card">
          <div class="feature-icon">🌙</div>
          <h3>Dark Mode</h3>
          <p>Easy on the eyes with automatic dark mode support. Matches your system preference.</p>
        </div>
      </div>
    </section>

    <!-- Quick Links Section -->
    <section class="links-section">
      <h2 class="section-title text-center">Explore More</h2>
      <div class="links-grid">
        <a href="/history" class="link-card glass-card">
          <h3>📖 History of Lorem Ipsum</h3>
          <p>Discover the fascinating 2000-year history of this classical Latin text.</p>
        </a>

        <a href="/usage" class="link-card glass-card">
          <h3>💡 Usage Guide</h3>
          <p>Learn how designers and developers use Lorem Ipsum effectively.</p>
        </a>

        <a href="/alternatives" class="link-card glass-card">
          <h3>🔄 Alternatives</h3>
          <p>Explore other placeholder text generators and dummy content tools.</p>
        </a>
      </div>
    </section>

    <!-- Developer API Section -->
    <section class="api-section">
      <div class="api-container glass-card">
        <h2 class="section-title text-center">For Developers</h2>
        <p class="api-intro text-center">
          Need Lorem Ipsum in your application? We've got you covered with both open-source and enterprise solutions.
        </p>

        <div class="api-grid">
          <div class="api-card">
            <div class="api-icon">📦</div>
            <h3>Lorelai - Open Source Go Library</h3>
            <p>
              A fast, lightweight Lorem Ipsum generator written in Go. Perfect for CLI tools, backend services, and automation scripts.
            </p>
            <div class="api-features">
              <span class="badge">MIT License</span>
              <span class="badge">Zero Dependencies</span>
              <span class="badge">Actively Maintained</span>
            </div>
            <a href="https://github.com/bobadilla-tech/lorelai" target="_blank" rel="noopener noreferrer" class="button button-secondary">
              View on GitHub →
            </a>
            <pre class="code-example"><code>go get github.com/bobadilla-tech/lorelai</code></pre>
          </div>

          <div class="api-card">
            <div class="api-icon">🚀</div>
            <h3>Enterprise API</h3>
            <p>
              Production-ready REST API for high-volume Lorem Ipsum generation. Scalable, reliable, and built for enterprise applications.
            </p>
            <div class="api-features">
              <span class="badge">99.9% Uptime</span>
              <span class="badge">Global CDN</span>
              <span class="badge">Rate Limiting</span>
            </div>
            <a href="https://requiems.xyz/" target="_blank" rel="noopener noreferrer" class="button button-primary">
              View API Docs →
            </a>
            <pre class="code-example"><code>curl https://requiems.xyz/v1/text/lorem</code></pre>
          </div>
        </div>

        <div class="company-plug">
          <p>
            Built by <a href="https://bobadilla.tech/" target="_blank" rel="noopener noreferrer" class="company-link"><strong>Bobadilla Tech</strong></a>
            - We build fast, reliable developer tools and enterprise solutions.
          </p>
          <div class="company-links">
            <a href="https://github.com/bobadilla-tech" target="_blank" rel="noopener noreferrer" class="social-link">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                <path d="M10 0C4.477 0 0 4.477 0 10c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0110 4.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C17.137 18.163 20 14.418 20 10c0-5.523-4.477-10-10-10z"/>
              </svg>
              GitHub
            </a>
            <a href="https://www.linkedin.com/company/bobadillatech/" target="_blank" rel="noopener noreferrer" class="social-link">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                <path d="M17.04 17.043h-2.962v-4.64c0-1.107-.02-2.531-1.542-2.531-1.544 0-1.78 1.205-1.78 2.449v4.722H7.793V7.5h2.844v1.302h.04c.397-.75 1.364-1.542 2.808-1.542 3.004 0 3.555 1.977 3.555 4.546v5.237zM4.447 6.194c-.954 0-1.72-.776-1.72-1.729 0-.953.766-1.729 1.72-1.729.95 0 1.72.776 1.72 1.729 0 .953-.77 1.729-1.72 1.729zm1.484 10.85h-2.97V7.5h2.97v9.543zM18.522 0H1.476C.66 0 0 .645 0 1.441v17.118C0 19.355.66 20 1.476 20h17.042c.815 0 1.482-.645 1.482-1.441V1.441C20.004.645 19.337 0 18.518 0h.003z"/>
              </svg>
              LinkedIn
            </a>
            <a href="https://bobadilla.tech/" target="_blank" rel="noopener noreferrer" class="social-link">
              🌐 Website
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script src="../scripts/generator-interactive.ts"></script>

<style>
  .hero-section {
    padding: 2rem 0;
    position: relative;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    inset: -15% -10% auto -10%;
    height: 140%;
    background:
      radial-gradient(circle at 20% 20%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 45%),
      radial-gradient(circle at 80% 25%, rgba(139, 92, 246, 0.14), transparent 45%),
      radial-gradient(circle at 50% 85%, color-mix(in srgb, var(--accent) 10%, transparent), transparent 50%);
    filter: blur(50px);
    z-index: -1;
    animation: hero-drift 18s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes hero-drift {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(2%, -2%) scale(1.05);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-section::before {
      animation: none;
    }
  }

  .feature-highlight {
    margin-top: 2rem;
    text-align: center;
  }

  .highlight-text {
    display: inline-block;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(139, 92, 246, 0.1));
    border: 2px solid var(--accent);
    border-radius: var(--radius-lg);
    font-size: 1.125rem;
    animation: pulse-border 2s ease-in-out infinite;
  }

  .highlight-text strong {
    color: var(--accent);
    font-weight: 700;
  }

  @keyframes pulse-border {
    0%, 100% {
      border-color: var(--accent);
      box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4);
    }
    50% {
      border-color: #8b5cf6;
      box-shadow: 0 0 0 8px rgba(59, 130, 246, 0);
    }
  }

  .highlight-card {
    border: 2px solid var(--accent);
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.05), rgba(139, 92, 246, 0.05));
  }

  .highlight-card .feature-icon {
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  .content-section {
    margin: 3rem 0;
  }

  .section-title {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2rem;
  }

  .content-main p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .sidebar-ad {
    position: sticky;
    top: 100px;
  }

  .content-card {
    padding: 2rem;
  }

  .content-card p {
    margin-bottom: 1.25rem;
    line-height: 1.8;
  }

  .quote-box {
    background: var(--bg-secondary);
    border-left: 4px solid var(--accent);
    padding: 1.5rem;
    margin: 2rem 0;
    border-radius: var(--radius-md);
    font-style: italic;
  }

  .classic-text {
    background: var(--bg-secondary);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    margin: 2rem 0;
  }

  .classic-text h3 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .latin-text {
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .inline-link {
    color: var(--accent);
    font-weight: 600;
    transition: color var(--transition-fast);
  }

  .inline-link:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }

  /* Features Section */
  .features-section {
    margin: 4rem 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .feature-card {
    padding: 2rem;
    text-align: center;
    transition: all var(--transition-normal);
  }

  .feature-card:hover {
    transform: translateY(-8px);
  }

  .feature-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .feature-card p {
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Links Section */
  .links-section {
    margin: 4rem 0;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .link-card {
    padding: 2rem;
    text-decoration: none;
    transition: all var(--transition-normal);
    display: block;
  }

  .link-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 64px var(--shadow);
  }

  .link-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
  }

  .link-card p {
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Ad Styles */
  .ad-leaderboard {
    margin: 3rem 0;
  }

  .ad-sidebar {
    margin: 0;
  }

  .ad-content {
    margin: 3rem auto;
    max-width: 600px;
  }

  /* API Section */
  .api-section {
    margin: 4rem 0;
  }

  .api-container {
    padding: 3rem 2rem;
    background: linear-gradient(135deg, var(--bg-glass) 0%, var(--bg-secondary) 100%);
  }

  .api-intro {
    font-size: 1.25rem;
    max-width: 700px;
    margin: 0 auto 3rem;
    color: var(--text-primary);
    font-weight: 400;
  }

  .api-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .api-card {
    background: var(--bg-primary);
    padding: 2.5rem;
    border-radius: var(--radius-xl);
    border: 2px solid var(--border);
    transition: all var(--transition-normal);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.05);
  }

  .api-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.15);
    border-color: var(--accent);
  }

  .api-icon {
    font-size: 3.5rem;
    margin-bottom: 1.5rem;
    display: block;
  }

  .api-card h3 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
    font-weight: 700;
  }

  .api-card p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    font-size: 1.0625rem;
  }

  .api-features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .badge {
    background: linear-gradient(135deg, var(--accent), #8b5cf6);
    color: white;
    padding: 0.375rem 1rem;
    border-radius: 2rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.025em;
    box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3);
  }

  .api-card .button {
    width: 100%;
    margin-bottom: 1.5rem;
    font-size: 1.0625rem;
    padding: 1rem;
  }

  .code-example {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    margin: 0;
    font-family: var(--font-mono);
    overflow-x: auto;
  }

  .code-example code {
    font-size: 0.9375rem;
    color: var(--accent);
    font-weight: 500;
  }

  .company-plug {
    text-align: center;
    padding-top: 3rem;
    border-top: 2px solid var(--border);
    margin-top: 2rem;
  }

  .company-plug p {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .company-link {
    color: var(--accent);
    text-decoration: none;
    font-weight: 700;
    transition: color var(--transition-fast);
  }

  .company-link:hover {
    color: var(--accent-hover);
  }

  .company-links {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
