---
import AdMobileAnchor from "../components/layout/AdMobileAnchor.astro";
import BaseHead from "../components/layout/BaseHead.astro";
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  keywords?: string[];
  image?: string;
  canonical?: string;
}

const { title, description, keywords, image, canonical } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      keywords={keywords}
      image={image}
      canonical={canonical}
    />
  </head>
  <body>
    <Header />
    <main class="main-content">
      <slot />
    </main>
    <Footer />
    <AdMobileAnchor adSlot="5566778899" />
  </body>
</html>

<style>
  .main-content {
    min-height: calc(100vh - 200px);
    padding: 2rem 0;
  }

  @media (max-width: 768px) {
    .main-content {
      padding-bottom: 5rem;
    }
  }
</style>
