---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us - Lorem Ipsum Generator"
  description="Get in touch with the Lorem Ipsum Generator team. We'd love to hear from you."
>
  <div class="container">
    <article class="content-article">
      <header class="article-header">
        <h1 class="article-title">Contact Us</h1>
        <p class="article-subtitle">We'd love to hear from you</p>
      </header>

      <div class="article-content">
        <section class="content-section">
          <div class="contact-grid">
            <div class="contact-card">
              <div class="contact-icon">🏢</div>
              <h3>Bobadilla Tech</h3>
              <p>We build fast, reliable developer tools and enterprise solutions.</p>
              <a href="https://bobadilla.tech/" target="_blank" rel="noopener noreferrer" class="button button-secondary">
                Visit Website →
              </a>
            </div>

            <div class="contact-card">
              <div class="contact-icon">💻</div>
              <h3>GitHub</h3>
              <p>Check out our open source projects and contribute to Lorelai.</p>
              <a href="https://github.com/bobadilla-tech" target="_blank" rel="noopener noreferrer" class="button button-secondary">
                View GitHub →
              </a>
            </div>

            <div class="contact-card">
              <div class="contact-icon">🔗</div>
              <h3>LinkedIn</h3>
              <p>Connect with us on LinkedIn for updates and company news.</p>
              <a href="https://www.linkedin.com/company/bobadillatech/" target="_blank" rel="noopener noreferrer" class="button button-secondary">
                Connect →
              </a>
            </div>
          </div>
        </section>

        <section class="content-section">
          <h2>For Developers</h2>
          <p>
            Need Lorem Ipsum in your application? Check out our developer solutions:
          </p>
          <ul class="developer-links">
            <li>
              <strong>Lorelai Go Library:</strong>
              <a href="https://github.com/bobadilla-tech/lorelai" target="_blank" rel="noopener noreferrer">
                Open source, MIT licensed, zero dependencies
              </a>
            </li>
            <li>
              <strong>Enterprise API:</strong>
              <a href="https://requiems.xyz/" target="_blank" rel="noopener noreferrer">
                Production-ready REST API for high-volume generation
              </a>
            </li>
          </ul>
        </section>

        <section class="content-section">
          <h2>Report Issues</h2>
          <p>
            Found a bug or have a suggestion? We welcome contributions and feedback:
          </p>
          <ul>
            <li>Open an issue on our GitHub repository</li>
            <li>Submit a pull request with improvements</li>
            <li>Share your feedback on social media</li>
          </ul>
        </section>

        <section class="content-section info-box">
          <h3>Business Inquiries</h3>
          <p>
            For business partnerships, custom development, or enterprise solutions, visit
            <a href="https://bobadilla.tech/" target="_blank" rel="noopener noreferrer">Bobadilla Tech</a>.
          </p>
        </section>
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .content-article {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .article-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--border);
  }

  .article-title {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .article-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
  }

  .article-content {
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .content-section {
    margin-bottom: 3rem;
  }

  .content-section h2 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin: 2rem 0;
  }

  .contact-card {
    background: var(--bg-secondary);
    padding: 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    text-align: center;
  }

  .contact-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .contact-card h3 {
    margin-bottom: 1rem;
  }

  .contact-card p {
    margin-bottom: 1.5rem;
    color: var(--text-secondary);
  }

  .contact-card .button {
    width: 100%;
  }

  .developer-links {
    list-style: none;
    padding: 0;
  }

  .developer-links li {
    padding: 1rem;
    margin-bottom: 1rem;
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--accent);
  }

  .developer-links strong {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .developer-links a {
    color: var(--accent);
  }

  .info-box {
    background: var(--bg-glass);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    border-left: 4px solid var(--accent);
  }

  .info-box h3 {
    margin-bottom: 1rem;
  }

  .info-box p {
    margin: 0;
  }

  @media (max-width: 768px) {
    .article-title {
      font-size: 2rem;
    }

    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
