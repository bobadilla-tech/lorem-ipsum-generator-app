---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-section">
        <h3>Lorem Ipsum Generator</h3>
        <p>The best free Lorem Ipsum generator for designers and developers. Fast, modern, and ad-optimized.</p>
      </div>

      <div class="footer-section">
        <h4>Quick Links</h4>
        <ul class="footer-links">
          <li><a href="/">Generator</a></li>
          <li><a href="/history">History</a></li>
          <li><a href="/usage">Usage Guide</a></li>
          <li><a href="/alternatives">Alternatives</a></li>
        </ul>
      </div>

      <div class="footer-section">
        <h4>Legal</h4>
        <ul class="footer-links">
          <li><a href="/privacy">Privacy Policy</a></li>
          <li><a href="/terms">Terms of Service</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-section">
        <h4>For Developers</h4>
        <ul class="footer-links">
          <li><a href="https://requiems-api.xyz/" target="_blank" rel="noopener noreferrer">Enterprise API</a></li>
          <li><a href="https://github.com/bobadilla-tech/lorelai" target="_blank" rel="noopener noreferrer">Lorelai (Go Library)</a></li>
          <li><a href="https://github.com/bobadilla-tech" target="_blank" rel="noopener noreferrer">GitHub</a></li>
        </ul>
      </div>

      <div class="footer-section">
        <h4>Resources</h4>
        <ul class="footer-links">
          <li><a href="https://en.wikipedia.org/wiki/Lorem_ipsum" target="_blank" rel="noopener noreferrer">Lorem Ipsum on Wikipedia</a></li>
          <li><a href="https://www.britannica.com/topic/Lorem-ipsum" target="_blank" rel="noopener noreferrer">Britannica Article</a></li>
          <li><a href="https://en.wikipedia.org/wiki/Cicero" target="_blank" rel="noopener noreferrer">About Cicero</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Lorem Ipsum Generator. All rights reserved.</p>
      <p class="footer-credit">
        Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a> by
        <a href="https://bobadilla.tech/" target="_blank" rel="noopener noreferrer"><strong>Bobadilla Tech</strong></a>
        • <a href="https://www.linkedin.com/company/bobadillatech/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    padding: 3rem 0 1.5rem;
    margin-top: 4rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer-section h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
    background: linear-gradient(135deg, var(--accent), #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-section h4 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
    font-weight: 600;
  }

  .footer-section p {
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.5rem;
  }

  .footer-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .footer-bottom {
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-bottom p {
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin: 0;
  }

  .footer-credit a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }

  .footer-credit a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
